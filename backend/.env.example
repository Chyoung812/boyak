PUBLIC_DATA_SERVICE_KEY=
DATABASE_URL=
PUBLIC_DATA_KEY_MODE=decoding

# 식약처/공공데이터 endpoints
DUR_PRDLST_INFO_BASE_URL=https://apis.data.go.kr/1471000/DURPrdlstInfoService03
EASY_DRUG_INFO_BASE_URL=https://apis.data.go.kr/1471000/DrbEasyDrugInfoService
DRUG_PRDT_PRMSN_INFO_BASE_URL=https://apis.data.go.kr/1471000/DrugPrdtPrmsnInfoService07
HTFS_INFO_BASE_URL=https://apis.data.go.kr/1471000/HtfsInfoService03
PILL_ID_INFO_BASE_URL=https://apis.data.go.kr/1471000/MdcinGrnIdntfcInfoService03

# 식품안전나라 경로형 API: /api/{keyId}/{serviceId}/{json|xml}/{startIdx}/{endIdx}
FOODSAFETY_API_KEY=
FOODSAFETY_BASE_URL=http://openapi.foodsafetykorea.go.kr/api
FOODSAFETY_SUPPLEMENT_INGREDIENT_SERVICE_ID=I0760

# TMap (길찾기/병원 주변 검색)
TMAP_APP_KEY=

# 카카오: 실제 키는 backend/.env에만. 프론트에 REST/Admin 키 금지.
KAKAO_REST_API_KEY=

# OpenAI: 선택사항. 없으면 룰 기반 fallback으로 동작.
# LLM은 진단/위험판정이 아니라 STT/자연어 입력 구조화에만 사용.
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o

# Groq (STT - whisper-large-v3-turbo)
GROQ_API_KEY=

# 네이버 클라우드 CLOVA OCR
NAVER_CLOVA_OCR_INVOKE_URL=
NAVER_CLOVA_OCR_SECRET=

# frontend dev
CORS_ORIGINS=http://localhost:3000
